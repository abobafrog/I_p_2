FROGGY_ADMIN_USERNAME=frog_admin
FROGGY_ADMIN_PASSWORD=replace-with-a-strong-secret
FROGGY_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://localhost:8080,http://127.0.0.1:8080
FROGGY_COOKIE_SECURE=false
FROGGY_COOKIE_SAMESITE=lax
FROGGY_TRANSLATION_API_BASE_URL=http://translator:5000
# Optional: set only if you switch the backend to a hosted LibreTranslate-compatible API.
FROGGY_TRANSLATION_API_KEY=
# Optional: timeout for translation requests in seconds.
FROGGY_TRANSLATION_TIMEOUT_SECONDS=10
VITE_API_BASE_URL=/api
